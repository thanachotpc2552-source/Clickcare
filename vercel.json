{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "clickcare-app/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/assets/(.*)", "dest": "clickcare-app/assets/$1" },
    { "src": "/(.*)\\.(js|css|png|svg|jpg|jpeg|gif|ico|json|woff|woff2|url)", "dest": "clickcare-app/$1" },
    { "src": "/(.*)", "dest": "clickcare-app/index.html" }
  ]
}
